# Two Very Auto Casino System - Environment Configuration Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env files with real credentials to version control

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=two_very_auto
DB_USER=your_username
DB_PASSWORD=your_secure_password
DB_SSL_MODE=require

# Redis Configuration (for caching and real-time features)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

# FastAPI Configuration
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000
FASTAPI_DEBUG=false
SECRET_KEY=your-super-secret-jwt-key-minimum-32-characters

# WebSocket Configuration
WS_HOST=localhost
WS_PORT=8001
WS_SSL_CERT=/path/to/ssl/cert.pem
WS_SSL_KEY=/path/to/ssl/key.pem

# Monitoring Configuration
MONITORING_ENABLED=true
METRICS_ENDPOINT=http://localhost:9090
LOG_LEVEL=INFO
LOG_FILE=/var/log/two_very_auto.log

# External Services
NOTIFICATION_SERVICE_URL=https://api.notifications.example.com
NOTIFICATION_API_KEY=your_notification_api_key

# Security Settings
CORS_ORIGINS=http://localhost:3000,https://your-domain.com
SESSION_TIMEOUT=3600
MAX_LOGIN_ATTEMPTS=5
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Packet Analysis Configuration
PACKET_CAPTURE_INTERFACE=eth0
PACKET_STORAGE_PATH=/var/data/packets
PACKET_RETENTION_DAYS=30

# Development Settings (set to false in production)
DEV_MODE=true
DEV_CORS_ENABLED=true
DEV_DEBUG_TOOLBAR=true

# Production Settings
PRODUCTION_MODE=false
SSL_VERIFY=true
SECURE_COOKIES=true
HSTS_ENABLED=true

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_SCHEDULE="0 2 * * *"  # Daily at 2 AM
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=your-backup-bucket
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key

# Feature Flags
FEATURE_AI_PREDICTION=true
FEATURE_REAL_TIME_ALERTS=true
FEATURE_ADVANCED_ANALYTICS=true
FEATURE_MULTI_CASINO_SUPPORT=true