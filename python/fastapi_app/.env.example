# Two Very Auto - FastAPI Configuration
# 환경 설정 예시 파일

# 서버 설정
HOST=127.0.0.1
PORT=8080

# 데이터베이스 설정
DATABASE_URL=sqlite:///./baccarat_optimized.db
DB_POOL_SIZE=10
DB_POOL_RECYCLE=3600

# 로깅 설정
LOG_LEVEL=INFO
LOG_FILE=./logs/fastapi.log

# 캐시 설정
CACHE_ENABLED=true
CACHE_TTL=3600
CACHE_MAX_SIZE=1000

# AI 예측 설정
AI_ENABLED=true
AI_MODEL_PATH=../models/
AI_PREDICTION_INTERVAL=30

# WebSocket 설정
WS_MAX_CONNECTIONS=100
WS_HEARTBEAT_INTERVAL=30

# 보안 설정
SECRET_KEY=your-secret-key-here
CORS_ORIGINS=["http://localhost:3000", "http://127.0.0.1:8080"]

# 알림 설정
NOTIFICATIONS_ENABLED=true
PAIR_ALERT_THRESHOLD=0.8

# 백업 설정
BACKUP_ENABLED=true
BACKUP_INTERVAL=3600
BACKUP_RETENTION_DAYS=30